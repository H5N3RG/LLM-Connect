# =========================================================
# LLM-Connect - Git Ignore
# =========================================================

# ---------------------------------------------------------
# Backups / Recovery
# ---------------------------------------------------------
*.bak
*.old
*.tmp
*.backup
*.orig
*.rej

# IDE recovery snapshots
*.pre_*

# ---------------------------------------------------------
# Archives / exports
# ---------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.7z

# ---------------------------------------------------------
# Lua / runtime junk
# ---------------------------------------------------------
*.luac

# ---------------------------------------------------------
# OS / editor junk
# ---------------------------------------------------------
.DS_Store
Thumbs.db

# KDE / Kate / KWrite
*.kate-swp
*.swp
*.swo

# ---------------------------------------------------------
# Logs
# ---------------------------------------------------------
*.log
debug.txt

# ---------------------------------------------------------
# Local test environments
# ---------------------------------------------------------
.minetest/
.luanti/
worlds/
mods/

# ---------------------------------------------------------
# Runtime-generated storage
# ---------------------------------------------------------
cache/
tmp/
temp/

# ---------------------------------------------------------
# Python junk (future tooling)
# ---------------------------------------------------------
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ---------------------------------------------------------
# Container / tooling
# ---------------------------------------------------------
podman-compose.override.yml
docker-compose.override.yml

# ---------------------------------------------------------
# AI / local model artifacts
# ---------------------------------------------------------
models/
embeddings/
vector_store/
.vecshot/

# ---------------------------------------------------------
# User secrets / local configs
# ---------------------------------------------------------
.env
.env.*
secrets.lua
local_config.lua

# ---------------------------------------------------------
# Generated documentation
# ---------------------------------------------------------
site/
dist/
build/
